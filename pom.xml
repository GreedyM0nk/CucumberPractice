<?xml version="1.0" encoding="UTF-8" standalone="no"?><project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>Cucumber</groupId>
    <artifactId>RetailAutomation</artifactId>
    <version>1.0-SNAPSHOT</version>

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <maven.compiler.release>21</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- Default environment — overridden by the active Maven profile or -Denv=xxx -->
        <env>uat</env>
        <!-- Java 21 LTS Feature Support (Java 25 features still usable via preview flags) -->
        <java.version>21</java.version>
    </properties>

    <dependencies>
        <!-- Selenium 4.x with Java 25 support (stable version) -->
        <dependency>
            <groupId>org.seleniumhq.selenium</groupId>
            <artifactId>selenium-java</artifactId>
            <version>4.15.0</version>
        </dependency>

        <dependency>
            <groupId>io.cucumber</groupId>
            <artifactId>cucumber-java</artifactId>
            <version>7.15.0</version>
        </dependency>
        <dependency>
            <groupId>io.cucumber</groupId>
            <artifactId>cucumber-junit</artifactId>
            <version>7.15.0</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>4.13.2</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>io.rest-assured</groupId>
            <artifactId>rest-assured</artifactId>
            <version>5.4.0</version>
            <exclusions>
                <exclusion>
                    <groupId>org.apache.commons</groupId>
                    <artifactId>commons-lang3</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>commons-codec</groupId>
                    <artifactId>commons-codec</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>org.hamcrest</groupId>
            <artifactId>hamcrest</artifactId>
            <version>2.2</version>
        </dependency>

        <!-- WebDriver Manager with Java 25 support (stable version) -->
        <dependency>
            <groupId>io.github.bonigarcia</groupId>
            <artifactId>webdrivermanager</artifactId>
            <version>6.1.0</version>
        </dependency>

        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>2.10.1</version>
        </dependency>

        <!-- Allure Reports (stable version with Java 25 compatibility) -->
        <dependency>
            <groupId>io.qameta.allure</groupId>
            <artifactId>allure-cucumber7-jvm</artifactId>
            <version>2.24.0</version>
        </dependency>


        <!-- Secure dependency versions to override vulnerable transitive dependencies -->
        <dependency>
            <groupId>commons-io</groupId>
            <artifactId>commons-io</artifactId>
            <version>2.15.1</version>
        </dependency>

        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-compress</artifactId>
            <version>1.26.0</version>
        </dependency>

        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-lang3</artifactId>
            <version>3.14.0</version>
        </dependency>

        <dependency>
            <groupId>commons-codec</groupId>
            <artifactId>commons-codec</artifactId>
            <version>1.17.0</version>
        </dependency>

        <!-- Jackson core upgraded to 2.16.1 to satisfy log4j-core 2.24.x which
             requires JacksonException (introduced in jackson-core 2.12).
             The transitive version pulled by other deps is 2.10.3, which lacks
             that class and causes a NoClassDefFoundError at startup.
             Updated to 2.16.1 to patch async parser DoS vulnerability (CVE-2024-50379). -->
        <!-- Jackson updated for security patches (stable version) -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-core</artifactId>
            <version>2.16.1</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.16.1</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
            <version>2.16.1</version>
        </dependency>

        <!-- Log4j 2.x with security patches (stable version with Java 25 support) -->
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-core</artifactId>
            <version>2.24.1</version>
        </dependency>
        
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-api</artifactId>
            <version>2.24.1</version>
        </dependency>

        <!-- SLF4J bridge for Log4j 2.x (stable version with Java 25 support) -->
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-slf4j2-impl</artifactId>
            <version>2.24.1</version>
        </dependency>
        
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>2.0.16</version>
        </dependency>

        <dependency>
            <groupId>com.browserstack</groupId>
            <artifactId>browserstack-java-sdk</artifactId>
            <version>1.20.1</version>
        </dependency>

    </dependencies>

    <!--
    ═══════════════════════════════════════════════════════════════════════
     ENVIRONMENT PROFILES
     ───────────────────────────────────────────────────────────────────
     Each profile sets the `env` system property, which ConfigReader uses
     to load the matching  src/test/resources/config/config-<env>.properties
     file that contains the URL, credentials, etc. for that environment.

     Usage (Maven command line):
       mvn test                         → UAT  (default, active by default)
       mvn test -Puat                   → UAT
       mvn test -Psit                   → SIT
       mvn test -Pprod                  → PROD
       mvn test -Denv=sit               → SIT  (direct system property, overrides profile)

     Usage (IntelliJ):
       Run → Edit Configurations → Maven → Profiles  → select sit / uat / prod
    ═══════════════════════════════════════════════════════════════════════
    -->
    <profiles>

        <!-- ── UAT (default) ─────────────────────────────────── -->
        <profile>
            <id>uat</id>
            <activation>
                <!-- Active when no other profile is explicitly selected -->
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <env>uat</env>
            </properties>
        </profile>

        <!-- ── SIT ───────────────────────────────────────────── -->
        <profile>
            <id>sit</id>
            <properties>
                <env>sit</env>
            </properties>
        </profile>

        <!-- ── PROD ──────────────────────────────────────────── -->
        <profile>
            <id>prod</id>
            <properties>
                <env>prod</env>
            </properties>
        </profile>

    </profiles>

    <build>
        <!-- Ensure all files under src/test/resources are copied to target/test-classes -->
        <testResources>
            <testResource>
                <directory>src/test/resources</directory>
                <includes>
                    <include>**/*</include>
                </includes>
            </testResource>
        </testResources>

        <plugins>
            <!--
                Pre-create target/allure-results before tests run.
                Without this, `mvn clean test` fails with:
                  "Directory target/allure-results not found"
                because `clean` wipes the target folder and Allure won't
                create the directory itself.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.1.0</version>
                <executions>
                    <execution>
                        <id>create-allure-results-dir</id>
                        <phase>generate-test-resources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.directory}/allure-results"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Maven Compiler Plugin with Java 21 preview features enabled for Java 25 compatibility -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <release>21</release>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <!--
                        Run each *Runner class in its own forked JVM.
                        forkCount=6 / reuseForks=false → true process isolation,
                        no ThreadLocal or static state can bleed between forks.
                        
                        Runners:
                        - ParallelRunner1: @S1 - Add Product to Cart
                        - ParallelRunner2: @S2 - Product Filtering
                        - ParallelRunner3: @S3 - Checkout Flow
                        - ParallelRunner4: @S4 - Authentication/Login
                        - ParallelRunner5: @S5 - Footer Navigation & Content
                        - ParallelRunner6: @S6 - Header Navigation
                    -->
                    <forkCount>6</forkCount>
                    <reuseForks>false</reuseForks>
                    <parallel>classes</parallel>
                    <threadCount>6</threadCount>

                    <systemPropertyVariables>
                        <!-- Forward the active profile's env value into every forked JVM -->
                        <env>${env}</env>
                        <allure.results.directory>${project.build.directory}/allure-results</allure.results.directory>
                    </systemPropertyVariables>

                    <!-- Keep running even if one runner fails so all 5 complete -->
                    <testFailureIgnore>true</testFailureIgnore>

                    <!-- Only the 5 dedicated parallel runners execute during mvn test -->
                    <includes>
                        <include>**/ParallelRunner*.java</include>
                    </includes>

                    <!-- Exclude legacy catch-all runners from the parallel run.
                         They can still be triggered individually: -Dtest=MyTestRunner -->
                    <excludes>
                        <exclude>**/MyTestRunner.java</exclude>
                        <exclude>**/SmokeTestRunner.java</exclude>
                        <exclude>**/RegressionTestRunner.java</exclude>
                        <exclude>**/UITestRunner.java</exclude>
                        <exclude>**/APITestRunner.java</exclude>
                    </excludes>

                    <!-- Enable preview features for Java 21 (Java 25 feature compatibility) -->
                    <argLine>--enable-preview -Xmx512m</argLine>
                </configuration>
            </plugin>

            <!-- Allure Report Maven Plugin - generates HTML reports from test results -->
            <plugin>
                <groupId>io.qameta.allure</groupId>
                <artifactId>allure-maven</artifactId>
                <version>2.12.0</version>
                <configuration>
                    <reportVersion>2.24.0</reportVersion>
                    <resultsDirectory>${project.build.directory}/allure-results</resultsDirectory>
                    <reportDirectory>${project.build.directory}/site/allure-report</reportDirectory>
                </configuration>
            </plugin>

            <!-- Maven Failsafe Plugin - executes integration tests and generates reports -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <systemPropertyVariables>
                        <env>${env}</env>
                        <allure.results.directory>${project.build.directory}/allure-results</allure.results.directory>
                    </systemPropertyVariables>
                    <testFailureIgnore>true</testFailureIgnore>
                    <!-- Enable preview features for Java 21 (Java 25 feature compatibility) -->
                    <argLine>--enable-preview</argLine>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <plugin>
        <artifactId>maven-dependency-plugin</artifactId>
        <version>3.3.0</version>
        <executions>
          <execution>
            <id>getClasspathFilenames</id>
            <goals>
              <goal>properties</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
        </plugins>
    </build>
</project>