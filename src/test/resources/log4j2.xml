<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p %c{1}:%L - %m%n"/>
        </Console>
        
        <File name="FileLogger" fileName="target/logs/automation.log" append="false">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p %c{1}:%L - %m%n"/>
        </File>
    </Appenders>
    
    <Loggers>
        <!-- Reduce noise from Selenium -->
        <Logger name="org.seleniumhq.selenium" level="WARN"/>
        <Logger name="org.openqa.selenium" level="WARN"/>
        
        <!-- Keep Cucumber and Allure logs at INFO level -->
        <Logger name="io.cucumber" level="INFO"/>
        <Logger name="io.qameta" level="INFO"/>
        
        <!-- Application logs -->
        <Logger name="com.retail" level="INFO"/>
        
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Root>
    </Loggers>
</Configuration>
